      <xs:documentation source="doc" xml:lang="pl">
        Organ i miejsce wydania potwierdzenia rejestracji zgłoszenia uproszczonego
      </xs:documentation>
      <xs:documentation source="doc" xml:lang="en">
        ......................................................
      </xs:documentation>
    </xs:annotation>
