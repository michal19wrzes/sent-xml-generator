          <xs:documentation source="doc" xml:lang="en">
            .........................................................
          </xs:documentation>
        </xs:annotation>
      </xs:enumeration>
      <xs:enumeration value="4">
        <xs:annotation>
          <xs:documentation source="doc" xml:lang="pl">
            Przedsiębiorstwo w spadku
          </xs:documentation>
          <xs:documentation source="doc" xml:lang="en">
            .........................
          </xs:documentation>
        </xs:annotation>
      </xs:enumeration>
    </xs:restriction>
  </xs:simpleType>
