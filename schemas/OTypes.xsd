      <xs:element name="TraderIdentityNumber" type="tp:TraderIdentityNumber" maxOccurs="1" minOccurs="1"/>
      <xs:element name="TraderDateOfDeath" type="tp:Date" minOccurs="0" maxOccurs="1">
