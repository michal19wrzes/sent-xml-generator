      <xs:element name="HeadOfTaxOfficeCode" type="op:HeadOfTaxOfficeCode" maxOccurs="1" minOccurs="1" />
      <xs:element name="HeadOfTaxOfficeName" type="op:HeadOfTaxOfficeName" maxOccurs="1" minOccurs="1" />
    </xs:sequence>
  </xs:complexType>
